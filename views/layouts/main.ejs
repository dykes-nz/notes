<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title><%= title %> - Notes</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="manifest" href="/manifest.json">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    /* Parsed before the Tailwind CDN script runs - stops hidden modals
       flashing as a white bar at the bottom during page load */
    .hidden { display: none !important; }

    body { font-family: 'Inter', sans-serif; }
    .bg-random {
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
      background-attachment: fixed;
    }
    .menu-icon {
      stroke: white;
      overflow: visible;
      filter: drop-shadow(0 1px 2px rgba(0,0,0,0.3));
    }
    .menu-icon.dark-stroke {
      stroke: #1f2937;
      filter: drop-shadow(0 1px 2px rgba(255,255,255,0.3));
    }
    .menu-item {
      color: white;
      text-shadow: 0 1px 2px rgba(0,0,0,0.3);
    }
    .menu-item:hover {
      opacity: 0.7;
    }
    .menu-dark .menu-item {
      color: #1f2937;
      text-shadow: 0 1px 2px rgba(255,255,255,0.3);
    }
    .menu-icon .line {
      transition: transform 0.5s ease;
      transform-box: fill-box;
      transform-origin: 0% 50%;
    }
    .menu-btn:hover .line-top,
    .menu-btn.menu-open .line-top {
      transform: translate(0px, 12px) rotate(-90deg);
    }
    .menu-btn:hover .line-middle,
    .menu-btn.menu-open .line-middle {
      transform: translate(0px, 6px) rotate(-45deg);
    }
    .menu-btn:hover .line-bottom,
    .menu-btn.menu-open .line-bottom {
      /* stays in place */
    }
    /* Decorative icon - matches hamburger color */
    .decorative-icon {
      stroke: white;
    }
    .decorative-icon.dark-stroke {
      stroke: #1f2937;
    }
  </style>
  <script>
    var backgrounds = [
      'aurora.jpg', 'bay.jpg', 'bike.jpg', 'cafe.jpg', 'crowd.jpg',
      'doors.jpg', 'ferris-wheel.jpg', 'field.jpg', 'forest.jpg', 'fuzzy-flowers.jpg',
      'grass.jpg', 'hills.jpg', 'indoors-white.jpg', 'japan.jpg', 'mobiles.jpg',
      'monkeys.jpg', 'moon.jpg', 'mural.jpg', 'neons.jpg', 'night.jpg',
      'outdoors-1.jpg', 'palm.jpg', 'park.jpg', 'pink-apartments.jpg', 'puffin.jpg',
      'races.jpg', 'road.jpg', 'roses.jpg', 'somewhere.jpg', 'springhills.jpg',
      'stars.jpg', 'street-neon.jpg', 'telescope.jpg', 'theme-park.jpg',
      'train-station.jpg', 'windmills.jpg'
    ];
    var randomBg = backgrounds[Math.floor(Math.random() * backgrounds.length)];
    document.write('<style>body { background-image: url("/backgrounds/' + randomBg + '"); }</style>');
  </script>
</head>
<body class="bg-random min-h-screen">
  <!-- Hamburger Menu -->
  <div class="fixed top-3 right-3 z-50">
    <button onclick="toggleMenu()" class="menu-btn p-3 rounded-xl">
      <svg class="menu-icon" id="menu-icon" style="width: 72px; height: 72px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <line class="line line-top" x1="4" y1="6" x2="20" y2="6" stroke-linecap="round" stroke-width="2.5"/>
        <line class="line line-middle" x1="4" y1="12" x2="20" y2="12" stroke-linecap="round" stroke-width="2.5"/>
        <line class="line line-bottom" x1="4" y1="18" x2="20" y2="18" stroke-linecap="round" stroke-width="2.5"/>
      </svg>
    </button>

    <!-- Dropdown Menu -->
    <div id="dropdown-menu" class="hidden absolute right-0 py-2 menu-light" style="top: calc(100% + 5px); font-family: 'Space Grotesk', sans-serif; min-width: 220px;">
      <button onclick="createNewNote(); toggleMenu();" class="menu-item block px-6 py-3 font-bold uppercase tracking-wide w-full text-right" style="font-size: 1.75rem;">NOTE</button>
      <button onclick="showImportModal(); toggleMenu();" class="menu-item block px-6 py-3 font-bold uppercase tracking-wide w-full text-right" style="font-size: 1.75rem;">PDF</button>
      <button onclick="showNewFolderModal(); toggleMenu();" class="menu-item block px-6 py-3 font-bold uppercase tracking-wide w-full text-right" style="font-size: 1.75rem;">FOLDER</button>
      <button onclick="showSearchModal(); toggleMenu();" class="menu-item block px-6 py-3 font-bold uppercase tracking-wide w-full text-right" style="font-size: 1.75rem;">SEARCH</button>
      <button onclick="toggleFullscreen(); toggleMenu();" class="menu-item block px-6 py-3 font-bold uppercase tracking-wide w-full text-right" style="font-size: 1.75rem;">FULL SCREEN</button>
      <a href="/settings" class="menu-item block px-6 py-3 font-bold uppercase tracking-wide text-right" style="font-size: 1.75rem;">SETTINGS</a>
    </div>
  </div>

  <!-- Main content -->
  <main class="min-h-screen pt-4 px-4">
    <%- body %>
  </main>

  <!-- New Folder Modal -->
  <div id="new-folder-modal" class="fixed inset-0 bg-black bg-opacity-50 z-50 hidden flex items-center justify-center">
    <div class="bg-white rounded-xl p-6 w-full max-w-sm mx-4">
      <h3 class="text-lg font-semibold mb-4">New Folder</h3>
      <form action="/folder" method="POST">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <input type="text" name="name" placeholder="Folder name" required
               class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 mb-4">
        <div class="flex justify-end gap-2">
          <button type="button" onclick="hideNewFolderModal()" class="px-4 py-2 text-gray-600 hover:bg-gray-100 rounded-lg">Cancel</button>
          <button type="submit" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">Create</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Search Modal -->
  <div id="search-modal" class="fixed inset-0 bg-black bg-opacity-50 z-50 hidden flex items-start justify-center pt-20">
    <div class="bg-white rounded-xl p-4 w-full max-w-lg mx-4 shadow-2xl">
      <div class="relative">
        <input type="text" id="search-input" placeholder="Search notes..." autofocus
               class="w-full px-4 py-3 pl-10 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
        <svg class="absolute left-3 top-3.5 w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <button onclick="hideSearchModal()" class="absolute right-3 top-3 text-gray-400 hover:text-gray-600">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
      <div id="search-results" class="mt-2 max-h-64 overflow-y-auto"></div>
    </div>
  </div>

  <script>
    function toggleMenu() {
      var menu = document.getElementById('dropdown-menu');
      var menuBtn = document.querySelector('.menu-btn');
      menu.classList.toggle('hidden');
      menuBtn.classList.toggle('menu-open', !menu.classList.contains('hidden'));
    }

    // Close menu when clicking outside
    document.addEventListener('click', function(e) {
      var menu = document.getElementById('dropdown-menu');
      var menuBtn = document.querySelector('.menu-btn');
      var clickedMenuBtn = e.target.closest('.menu-btn');
      if (!menu.contains(e.target) && !clickedMenuBtn) {
        menu.classList.add('hidden');
        menuBtn.classList.remove('menu-open');
      }
    });

    function showNewFolderModal() {
      document.getElementById('new-folder-modal').classList.remove('hidden');
    }

    function hideNewFolderModal() {
      document.getElementById('new-folder-modal').classList.add('hidden');
    }

    function showSearchModal() {
      document.getElementById('search-modal').classList.remove('hidden');
      document.getElementById('search-input').focus();
    }

    function hideSearchModal() {
      document.getElementById('search-modal').classList.add('hidden');
      document.getElementById('search-input').value = '';
      document.getElementById('search-results').innerHTML = '';
    }

    // Search functionality
    var searchTimeout = null;
    document.getElementById('search-input')?.addEventListener('input', function() {
      clearTimeout(searchTimeout);
      var query = this.value.trim();
      var resultsEl = document.getElementById('search-results');

      if (query.length < 2) {
        resultsEl.innerHTML = '';
        return;
      }

      searchTimeout = setTimeout(function() {
        fetch('/search?q=' + encodeURIComponent(query))
          .then(function(r) { return r.json(); })
          .then(function(notes) {
            if (notes.length === 0) {
              resultsEl.innerHTML = '<p class="p-4 text-gray-500">No results found</p>';
            } else {
              resultsEl.innerHTML = notes.map(function(note) {
                return '<a href="/note/' + note.id + '" class="block px-4 py-3 hover:bg-gray-100 rounded-lg">' + (note.title || 'Untitled') + '</a>';
              }).join('');
            }
          });
      }, 300);
    });

    // Close search on escape
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        hideSearchModal();
      }
    });

    // Create new note with blank canvas
    function createNewNote() {
      fetch('/note', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ title: 'New Note', folder_id: null })
      }).then(function(r) { return r.json(); })
        .then(function(result) {
          if (result.noteId) {
            window.location.href = '/note/' + result.noteId;
          }
        }).catch(function(err) {
          console.error('Error creating note:', err);
          alert('Failed to create note');
        });
    }

    // Show import modal (defined in index page, fallback here)
    function showImportModal() {
      var modal = document.getElementById('import-modal');
      if (modal) {
        modal.classList.remove('hidden');
      } else {
        // Redirect to home if not on index page
        window.location.href = '/?import=1';
      }
    }

    // Toggle fullscreen
    function toggleFullscreen() {
      if (!document.fullscreenElement) {
        document.documentElement.requestFullscreen().catch(function(err) {
          console.log('Fullscreen error:', err);
        });
      } else {
        document.exitFullscreen();
      }
    }

    // Detect background brightness and adjust hamburger color
    function adjustMenuContrast() {
      var img = new Image();
      img.crossOrigin = 'anonymous';
      img.onload = function() {
        var canvas = document.createElement('canvas');
        var ctx = canvas.getContext('2d');

        // Sample the top-right corner area (where hamburger is)
        var sampleWidth = 120;
        var sampleHeight = 120;
        canvas.width = sampleWidth;
        canvas.height = sampleHeight;

        // Calculate source coordinates (top-right of the image, accounting for cover scaling)
        var imgRatio = img.width / img.height;
        var winRatio = window.innerWidth / window.innerHeight;
        var srcX, srcY, srcW, srcH;

        if (imgRatio > winRatio) {
          // Image is wider - height fills, width is cropped
          srcH = img.height;
          srcW = img.height * winRatio;
          srcX = img.width - srcW; // Right side
          srcY = 0; // Top
        } else {
          // Image is taller - width fills, height is cropped
          srcW = img.width;
          srcH = img.width / winRatio;
          srcX = img.width - (sampleWidth / window.innerWidth) * srcW;
          srcY = 0;
        }

        // Draw the top-right portion
        var sampleSrcW = (sampleWidth / window.innerWidth) * srcW;
        var sampleSrcH = (sampleHeight / window.innerHeight) * srcH;
        ctx.drawImage(img, img.width - sampleSrcW, 0, sampleSrcW, sampleSrcH, 0, 0, sampleWidth, sampleHeight);

        // Get pixel data and calculate luminance
        var imageData = ctx.getImageData(0, 0, sampleWidth, sampleHeight);
        var data = imageData.data;
        var totalLuminance = 0;
        var pixelCount = 0;

        for (var i = 0; i < data.length; i += 4) {
          var r = data[i];
          var g = data[i + 1];
          var b = data[i + 2];
          // Relative luminance formula
          totalLuminance += (0.299 * r + 0.587 * g + 0.114 * b);
          pixelCount++;
        }

        var avgLuminance = totalLuminance / pixelCount;
        var menuIcon = document.getElementById('menu-icon');
        var dropdownMenu = document.getElementById('dropdown-menu');
        var decorativeIcon = document.getElementById('decorative-quill');

        // If background is light (luminance > 128), use dark stroke/text
        if (avgLuminance > 140) {
          menuIcon.classList.add('dark-stroke');
          dropdownMenu.classList.add('menu-dark');
          dropdownMenu.classList.remove('menu-light');
          if (decorativeIcon) decorativeIcon.classList.add('dark-stroke');
        } else {
          menuIcon.classList.remove('dark-stroke');
          dropdownMenu.classList.remove('menu-dark');
          dropdownMenu.classList.add('menu-light');
          if (decorativeIcon) decorativeIcon.classList.remove('dark-stroke');
        }
      };
      img.src = '/backgrounds/' + randomBg;
    }

    // Run contrast detection after page loads
    window.addEventListener('load', adjustMenuContrast);
    window.addEventListener('resize', adjustMenuContrast);
  </script>
</body>
</html>
