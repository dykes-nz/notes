<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login - Notes</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    body { font-family: 'Inter', sans-serif; }
    .bg-random {
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
    }
  </style>
  <script>
    var backgrounds = [
      'aurora.jpg', 'bike.jpg', 'cafe.jpg', 'ferris-wheel.jpg', 'field.jpg',
      'fuzzy-flowers.jpg', 'hills.jpg', 'indoors-white.jpg', 'monkeys.jpg', 'night.jpg',
      'outdoors-1.jpg', 'palm.jpg', 'puffin.jpg', 'somewhere.jpg', 'telescope.jpg',
      'train-station.jpg', 'windmills.jpg'
    ];
    var randomBg = backgrounds[Math.floor(Math.random() * backgrounds.length)];
    document.write('<style>body { background-image: url("/backgrounds/' + randomBg + '"); }</style>');
  </script>
</head>
<body class="bg-random min-h-screen flex items-center justify-center">
  <div class="text-center p-8 w-full max-w-md mx-4">
    <!-- Quill and book SVG - clickable login button -->
    <button type="button" id="passkey-btn" onclick="handlePasskey()"
            class="focus:outline-none transition-transform hover:scale-105 active:scale-95">
      <svg class="w-48 h-48 mx-auto" viewBox="0 0 92.69 75.53" fill="none" stroke="white" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" style="filter: drop-shadow(0 2px 4px rgba(0,0,0,0.3));">
        <path d="M48.99,65.62c-7.6-14.01-17.33-18.52-28.96-22.13l14.96-24.21c5.03.08,7.28,1.21,10.19,4.91"/>
        <path d="M37.17,57.88c-8.12-6.51-18.33-9.59-29.11-10.37l20.07-27.78"/>
        <path d="M41.55,64c-12.49-4.65-23.16-7.25-34.69-6.78l2.26-3.85"/>
        <path d="M43.81,68.52c-12.76-3.19-23.63-3.22-35.75-3.59l1.2-3.19"/>
        <path d="M51.26,31.47c-.76,1.56-.48,2.25.38,3.43,2.77-1.49,7.04-5.42,11.36-9.44"/>
        <path d="M46.28,44.53c2.89-1.9,4.8-3.35,7.3-6.16,2.44,1.38,4.74.49,7.69-.45"/>
        <path d="M61.7,33.63c1.54,1.03,3.41.76,5.06.25,2.95-1.65,5.19-2.89,7.26-5.38-1.79-.36-3.35-.95-4.51-1.97"/>
        <path d="M52.72,27.86c.94-3.24,1.33-4.9,4.34-6.8"/>
        <path d="M60.66,21.36c.89-2.93,2.83-5.01,5.37-6.5"/>
        <path d="M69.63,16.35c.12-5.47,11.61-5.95,18.01-5.85-7.24,5.56-8.25,12.18-11.64,14.86"/>
      </svg>
    </button>

    <p id="status" class="mt-6 text-center text-sm text-white/80" style="text-shadow: 0 1px 2px rgba(0,0,0,0.3);"></p>
  </div>

  <script>
    var statusEl = document.getElementById('status');
    var passkeyBtn = document.getElementById('passkey-btn');

    // Check WebAuthn support
    if (!window.PublicKeyCredential) {
      statusEl.textContent = 'Your browser does not support passkeys. Please use a modern browser.';
      statusEl.style.color = '#dc2626';
      passkeyBtn.disabled = true;
      passkeyBtn.style.opacity = '0.5';
    }

    // Dynamic handler that checks setup status first
    async function handlePasskey() {
      try {
        var res = await fetch('/auth/setup-needed');
        var data = await res.json();
        if (data.setupNeeded) {
          await setupPasskey();
        } else {
          await loginWithPasskey();
        }
      } catch (err) {
        console.error('Error checking setup status:', err);
        statusEl.textContent = 'Error: ' + err.message;
        statusEl.style.color = '#dc2626';
      }
    }

    // Base64url conversion utilities
    function base64urlToBuffer(base64url) {
      var base64 = base64url.replace(/-/g, '+').replace(/_/g, '/');
      var padding = '='.repeat((4 - base64.length % 4) % 4);
      var binary = atob(base64 + padding);
      var bytes = new Uint8Array(binary.length);
      for (var i = 0; i < binary.length; i++) {
        bytes[i] = binary.charCodeAt(i);
      }
      return bytes.buffer;
    }

    function bufferToBase64url(buffer) {
      var bytes = new Uint8Array(buffer);
      var binary = '';
      for (var i = 0; i < bytes.length; i++) {
        binary += String.fromCharCode(bytes[i]);
      }
      return btoa(binary).replace(/\+/g, '-').replace(/\//g, '_').replace(/=+$/, '');
    }

    // Detect device name
    function getDeviceName() {
      var ua = navigator.userAgent;
      if (/iPhone/.test(ua)) return 'iPhone';
      if (/iPad/.test(ua)) return 'iPad';
      if (/Macintosh/.test(ua) && navigator.maxTouchPoints > 0) return 'iPad';
      if (/Macintosh/.test(ua)) return 'Mac';
      if (/Android/.test(ua)) return 'Android';
      if (/Windows/.test(ua)) return 'Windows';
      return 'Unknown Device';
    }

    async function setupPasskey() {
      console.log('setupPasskey called');
      passkeyBtn.textContent = 'Setting up...';
      passkeyBtn.disabled = true;
      statusEl.textContent = '';

      try {
        // Check WebAuthn support
        if (!window.PublicKeyCredential) {
          throw new Error('WebAuthn not supported in this browser');
        }

        console.log('Fetching register options...');
        // Get registration options
        var optionsRes = await fetch('/auth/passkey/register-options');
        var options = await optionsRes.json();
        console.log('Got options:', options);

        if (options.error) {
          throw new Error(options.error);
        }

        // Convert from base64url
        options.challenge = base64urlToBuffer(options.challenge);
        options.user.id = base64urlToBuffer(options.user.id);
        if (options.excludeCredentials) {
          options.excludeCredentials = options.excludeCredentials.map(function(c) {
            return { ...c, id: base64urlToBuffer(c.id) };
          });
        }

        console.log('Creating credential...');
        // Create credential
        var credential = await navigator.credentials.create({ publicKey: options });
        console.log('Credential created:', credential);

        // Prepare response
        var response = {
          id: credential.id,
          rawId: bufferToBase64url(credential.rawId),
          type: credential.type,
          response: {
            clientDataJSON: bufferToBase64url(credential.response.clientDataJSON),
            attestationObject: bufferToBase64url(credential.response.attestationObject),
          },
        };
        if (credential.response.getTransports) {
          response.response.transports = credential.response.getTransports();
        }

        // Register with server
        var verifyRes = await fetch('/auth/passkey/register', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ response: response, deviceName: getDeviceName() })
        });
        var result = await verifyRes.json();

        if (result.success) {
          statusEl.textContent = 'Passkey set up successfully!';
          statusEl.style.color = '#059669';
          window.location.href = '/';
        } else {
          throw new Error(result.error || 'Setup failed');
        }
      } catch (err) {
        console.error('Setup error:', err);
        statusEl.textContent = 'Setup failed: ' + err.message;
        statusEl.style.color = '#dc2626';
        passkeyBtn.textContent = 'Set up Face ID / Touch ID';
        passkeyBtn.disabled = false;
      }
    }

    async function loginWithPasskey() {
      passkeyBtn.textContent = 'Authenticating...';
      passkeyBtn.disabled = true;
      statusEl.textContent = '';

      try {
        // Get authentication options
        var optionsRes = await fetch('/auth/passkey/login-options');
        var options = await optionsRes.json();

        if (options.error) {
          throw new Error(options.error);
        }

        // Convert from base64url
        options.challenge = base64urlToBuffer(options.challenge);
        if (options.allowCredentials) {
          options.allowCredentials = options.allowCredentials.map(function(c) {
            return { ...c, id: base64urlToBuffer(c.id) };
          });
        }

        // Authenticate
        var credential = await navigator.credentials.get({ publicKey: options });

        // Prepare response
        var response = {
          id: credential.id,
          rawId: bufferToBase64url(credential.rawId),
          type: credential.type,
          response: {
            clientDataJSON: bufferToBase64url(credential.response.clientDataJSON),
            authenticatorData: bufferToBase64url(credential.response.authenticatorData),
            signature: bufferToBase64url(credential.response.signature),
          },
        };
        if (credential.response.userHandle) {
          response.response.userHandle = bufferToBase64url(credential.response.userHandle);
        }

        // Verify with server
        var verifyRes = await fetch('/auth/passkey/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ response: response })
        });
        var result = await verifyRes.json();

        if (result.success) {
          window.location.href = result.redirect || '/';
        } else {
          throw new Error(result.error || 'Login failed');
        }
      } catch (err) {
        console.error('Login error:', err);
        if (err.name === 'NotAllowedError') {
          statusEl.textContent = 'Authentication cancelled';
        } else {
          statusEl.textContent = 'Login failed: ' + err.message;
        }
        statusEl.style.color = '#dc2626';
        passkeyBtn.textContent = 'Sign in with Face ID / Touch ID';
        passkeyBtn.disabled = false;
      }
    }
  </script>
</body>
</html>
