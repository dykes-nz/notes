<%- include('../layouts/main', { body: `
<!-- Decorative quill and book icon -->
<svg id="decorative-quill" class="fixed bottom-8 left-8 w-32 h-32 pointer-events-none decorative-icon" style="opacity: 0.2;" viewBox="0 0 92.69 75.53" fill="none" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5">
  <path d="M48.99,65.62c-7.6-14.01-17.33-18.52-28.96-22.13l14.96-24.21c5.03.08,7.28,1.21,10.19,4.91"/>
  <path d="M37.17,57.88c-8.12-6.51-18.33-9.59-29.11-10.37l20.07-27.78"/>
  <path d="M41.55,64c-12.49-4.65-23.16-7.25-34.69-6.78l2.26-3.85"/>
  <path d="M43.81,68.52c-12.76-3.19-23.63-3.22-35.75-3.59l1.2-3.19"/>
  <path d="M51.26,31.47c-.76,1.56-.48,2.25.38,3.43,2.77-1.49,7.04-5.42,11.36-9.44"/>
  <path d="M46.28,44.53c2.89-1.9,4.8-3.35,7.3-6.16,2.44,1.38,4.74.49,7.69-.45"/>
  <path d="M61.7,33.63c1.54,1.03,3.41.76,5.06.25,2.95-1.65,5.19-2.89,7.26-5.38-1.79-.36-3.35-.95-4.51-1.97"/>
  <path d="M52.72,27.86c.94-3.24,1.33-4.9,4.34-6.8"/>
  <path d="M60.66,21.36c.89-2.93,2.83-5.01,5.37-6.5"/>
  <path d="M69.63,16.35c.12-5.47,11.61-5.95,18.01-5.85-7.24,5.56-8.25,12.18-11.64,14.86"/>
</svg>

<style>
  /* Suppress iOS long-press link preview so protracted touch can rename */
  .note-card a { -webkit-touch-callout: none; -webkit-user-select: none; user-select: none; }
  /* Drag handle has no hover state on touch devices - keep it faintly visible */
  @media (hover: none) {
    .note-drag-handle { opacity: 0.35; }
  }
  .title-edit {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.25rem;
    font-weight: 600;
    color: #1f2937;
    width: 100%;
    background: rgba(255,255,255,0.85);
    border: 1px solid #93c5fd;
    border-radius: 6px;
    padding: 2px 8px;
    outline: none;
  }
  /* iOS-style folder tiles */
  .folder-tile {
    border-width: 2px;
    border-color: rgba(255,255,255,0.7);
  }
  .mini-note {
    background: rgba(255,255,255,0.85);
    border: 1px solid #e5e7eb;
    border-radius: 6px;
    padding: 4px 6px;
    font-size: 10px;
    font-weight: 600;
    color: #4b5563;
    height: 30px;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
    line-height: 22px;
  }
  .mini-note.mini-empty {
    background: rgba(255,255,255,0.3);
    border-style: dashed;
  }
  /* Drop-to-combine highlight (iOS folder-creation hover) */
  .combine-target {
    outline: 3px solid #3b82f6;
    outline-offset: 3px;
    transform: scale(1.03);
    transition: transform 0.1s;
  }
  .overlay-note { -webkit-touch-callout: none; -webkit-user-select: none; user-select: none; }
</style>

<div class="mx-auto" style="max-width: calc(100% - 400px); margin: 200px 200px 0 200px;">
  <!-- Grid: folder tiles and loose notes share one ordering -->
  <div id="notes-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
    ${gridItems.length === 0 ? `` : gridItems.map((item, index) => item.kind === 'folder' ? `
    <div class="note-card folder-tile bg-white/20 backdrop-blur-sm rounded-xl p-4 hover:shadow-lg hover:bg-white/40 transition relative group" draggable="false" data-folder-id="${item.folder.id}" data-index="${index}">
      <div class="note-drag-handle absolute top-3 left-3 cursor-grab text-gray-300 hover:text-gray-500 opacity-0 group-hover:opacity-100 transition-opacity" title="Drag to reorder">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
          <circle cx="9" cy="6" r="2"/>
          <circle cx="9" cy="12" r="2"/>
          <circle cx="9" cy="18" r="2"/>
          <circle cx="15" cy="6" r="2"/>
          <circle cx="15" cy="12" r="2"/>
          <circle cx="15" cy="18" r="2"/>
        </svg>
      </div>
      <div class="block pl-6 cursor-pointer">
        <div class="grid grid-cols-2 gap-1.5 mb-2 pointer-events-none">
          ${item.folder.notes.slice(0, 4).map(n => `<div class="mini-note">${n.title || 'Untitled'}</div>`).join('')}
          ${item.folder.notes.length < 4 ? Array(4 - Math.min(item.folder.notes.length, 4)).fill('<div class="mini-note mini-empty"></div>').join('') : ''}
        </div>
        <h3 class="font-semibold text-gray-800 truncate pr-8" style="font-family: 'Space Grotesk', sans-serif; font-size: 1.25rem;">${item.folder.name}</h3>
        <p class="text-sm text-gray-500">${item.folder.notes.length} notes</p>
      </div>
    </div>
    ` : `
    <div class="note-card bg-white/30 backdrop-blur-sm rounded-xl border border-gray-200 p-4 hover:shadow-lg hover:bg-white/60 transition relative group" draggable="false" data-note-id="${item.note.id}" data-index="${index}">
      <div class="note-drag-handle absolute top-3 left-3 cursor-grab text-gray-300 hover:text-gray-500 opacity-0 group-hover:opacity-100 transition-opacity" title="Drag to reorder">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
          <circle cx="9" cy="6" r="2"/>
          <circle cx="9" cy="12" r="2"/>
          <circle cx="9" cy="18" r="2"/>
          <circle cx="15" cy="6" r="2"/>
          <circle cx="15" cy="12" r="2"/>
          <circle cx="15" cy="18" r="2"/>
        </svg>
      </div>
      <a href="/note/${item.note.id}" class="block pl-6">
        <h3 class="font-semibold text-gray-800 mb-2 truncate pr-8" style="font-family: 'Space Grotesk', sans-serif; font-size: 1.25rem;">${item.note.title || 'Untitled'}</h3>
        <p class="text-sm text-gray-500">Updated ${new Date(item.note.updated_at).toLocaleDateString()}</p>
      </a>
      <button onclick="confirmDeleteNote(${item.note.id}, '${(item.note.title || 'Untitled').replace(/'/g, "\\'")}')"
              class="absolute top-3 right-3 p-1.5 text-gray-400 hover:text-red-500 hover:bg-red-50 rounded-lg opacity-0 group-hover:opacity-100 transition-opacity"
              title="Delete note">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
        </svg>
      </button>
    </div>
    `).join('')}
  </div>
</div>

<!-- Delete Confirmation Modal -->
<div id="delete-modal" class="fixed inset-0 bg-black bg-opacity-50 z-50 hidden flex items-center justify-center">
  <div class="bg-white rounded-xl p-6 w-full max-w-sm mx-4">
    <h3 class="text-lg font-semibold text-gray-800 mb-3">Delete Note</h3>
    <p class="text-gray-600 mb-4">Are you sure you want to delete "<span id="delete-note-title" class="font-medium"></span>"? This will permanently remove the note and all its contents.</p>
    <div class="flex justify-end gap-3">
      <button onclick="hideDeleteModal()" class="px-4 py-2 text-gray-600 hover:bg-gray-100 rounded-lg">Cancel</button>
      <button onclick="executeDeleteNote()" class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700">Delete</button>
    </div>
  </div>
</div>

<!-- Import PDF Modal -->
<div id="import-modal" class="fixed inset-0 bg-black bg-opacity-50 z-50 hidden flex items-center justify-center">
  <div class="bg-white rounded-xl p-6 w-full max-w-md mx-4">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-lg font-semibold">Import PDF</h3>
      <button onclick="hideImportModal()" class="text-gray-400 hover:text-gray-600">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
    <div id="dropzone" class="border-2 border-dashed border-gray-300 rounded-xl p-8 text-center hover:border-blue-500 hover:bg-blue-50 transition cursor-pointer"
         onclick="document.getElementById('pdf-input').click()">
      <svg class="w-12 h-12 mx-auto text-gray-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/>
      </svg>
      <p class="text-gray-600 mb-2">Drop PDF here or click to browse</p>
      <p class="text-sm text-gray-400">PDF files only</p>
    </div>
    <input type="file" id="pdf-input" accept="application/pdf" class="hidden" onchange="handlePdfSelect(this.files[0])">
    <div id="upload-progress" class="hidden mt-4">
      <div class="flex items-center">
        <div class="animate-spin rounded-full h-5 w-5 border-b-2 border-blue-600 mr-3"></div>
        <span class="text-gray-600">Uploading...</span>
      </div>
    </div>
  </div>
</div>

<!-- Folder overlay (iOS-style expanded folder) -->
<div id="folder-overlay" class="fixed inset-0 bg-black bg-opacity-40 z-50 hidden flex items-center justify-center">
  <div id="folder-overlay-panel" class="bg-white/85 backdrop-blur-md rounded-2xl p-6 w-full max-w-2xl mx-4 shadow-2xl" style="max-height: 70vh; overflow-y: auto;">
    <h2 id="folder-overlay-title" class="text-xl font-bold text-gray-800 mb-4 truncate" style="font-family: 'Space Grotesk', sans-serif;">Folder</h2>
    <div id="folder-overlay-grid" class="grid grid-cols-2 md:grid-cols-3 gap-3"></div>
    <p class="text-xs text-gray-500 mt-4">Drag a note out of this panel to remove it from the folder. Touch and hold the folder name on the home screen to rename it.</p>
  </div>
</div>

<script>
  var currentFolderId = '${typeof currentFolder !== 'undefined' && currentFolder ? currentFolder.id : ''}';
  var FOLDERS_DATA = ${JSON.stringify(foldersWithNotes.map(f => ({
    id: f.id,
    name: f.name,
    notes: f.notes.map(n => ({ id: n.id, title: n.title, updated_at: n.updated_at }))
  }))).replace(/</g, '\\u003c')};
  var noteToDelete = null;

  // Long-press a note card to rename it inline; a quick tap opens the note
  var LONG_PRESS_MS = 550;
  var pressTimer = null;
  var pressStart = null;
  var suppressClick = false;

  function startInlineRename(card) {
    var noteId = card.dataset.noteId;
    var folderId = card.dataset.folderId;
    var h3 = card.querySelector('h3');
    if (!h3 || h3.querySelector('input')) return;

    var current = h3.textContent;
    var input = document.createElement('input');
    input.type = 'text';
    input.className = 'title-edit';
    input.value = current;
    h3.textContent = '';
    h3.appendChild(input);
    input.focus();
    input.select();

    var done = false;
    function finish(save) {
      if (done) return;
      done = true;
      var newTitle = input.value.trim();
      input.remove();

      if (save && newTitle && newTitle !== current) {
        h3.textContent = newTitle;
        var url = folderId ? '/folder/' + folderId + '/rename' : '/note/' + noteId + '/title';
        var body = folderId ? { name: newTitle } : { title: newTitle };
        fetch(url, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body)
        }).then(function(r) { return r.json(); })
          .then(function(result) {
            if (!result.success) throw new Error(result.error || 'Rename failed');
            if (folderId) {
              var f = FOLDERS_DATA.find(function(x) { return x.id === parseInt(folderId); });
              if (f) f.name = newTitle;
            }
          }).catch(function(err) {
            h3.textContent = current;
            alert('Failed to rename: ' + err.message);
          });
      } else {
        h3.textContent = current;
      }
    }

    input.addEventListener('blur', function() { finish(true); });
    input.addEventListener('keydown', function(e) {
      if (e.key === 'Enter') { e.preventDefault(); input.blur(); }
      if (e.key === 'Escape') finish(false);
    });
    // Interacting with the input must not follow the card link
    input.addEventListener('click', function(e) { e.preventDefault(); e.stopPropagation(); });
  }

  document.addEventListener('pointerdown', function(e) {
    var card = e.target.closest('.note-card');
    if (!card || e.target.closest('button') || e.target.closest('input') || e.target.closest('.note-drag-handle')) return;
    pressStart = { x: e.clientX, y: e.clientY };
    pressTimer = setTimeout(function() {
      pressTimer = null;
      suppressClick = true;
      setTimeout(function() { suppressClick = false; }, 600);
      startInlineRename(card);
    }, LONG_PRESS_MS);
  });

  document.addEventListener('pointermove', function(e) {
    if (pressTimer && pressStart &&
        (Math.abs(e.clientX - pressStart.x) > 10 || Math.abs(e.clientY - pressStart.y) > 10)) {
      clearTimeout(pressTimer);
      pressTimer = null;
    }
  });

  ['pointerup', 'pointercancel'].forEach(function(evt) {
    document.addEventListener(evt, function() {
      if (pressTimer) { clearTimeout(pressTimer); pressTimer = null; }
    });
  });

  // Swallow the click that follows a completed long-press
  document.addEventListener('click', function(e) {
    if (suppressClick && e.target.closest('.note-card')) {
      e.preventDefault();
      e.stopPropagation();
      suppressClick = false;
    }
  }, true);

  // ============= FOLDER OVERLAY (iOS-style) =============

  function escapeHtml(s) {
    return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  var overlayDraggedNoteId = null;

  function openFolderOverlay(folderId) {
    var folder = FOLDERS_DATA.find(function(f) { return f.id === folderId; });
    if (!folder) return;

    document.getElementById('folder-overlay-title').textContent = folder.name;
    var grid = document.getElementById('folder-overlay-grid');
    grid.innerHTML = folder.notes.map(function(n) {
      return '<div class="overlay-note bg-white rounded-lg p-3 shadow cursor-pointer hover:shadow-md" draggable="true" data-note-id="' + n.id + '">' +
        '<h4 class="font-semibold text-gray-800 truncate text-sm">' + escapeHtml(n.title || 'Untitled') + '</h4>' +
        '<p class="text-xs text-gray-500 mt-1">' + new Date(n.updated_at).toLocaleDateString() + '</p>' +
        '</div>';
    }).join('');

    grid.querySelectorAll('.overlay-note').forEach(function(el) {
      el.addEventListener('click', function() {
        window.location.href = '/note/' + el.dataset.noteId;
      });
      el.addEventListener('dragstart', function(e) {
        overlayDraggedNoteId = el.dataset.noteId;
        el.style.opacity = '0.5';
        e.dataTransfer.effectAllowed = 'move';
      });
      el.addEventListener('dragend', function() {
        el.style.opacity = '1';
        overlayDraggedNoteId = null;
      });
    });

    document.getElementById('folder-overlay').classList.remove('hidden');
  }

  function closeFolderOverlay() {
    document.getElementById('folder-overlay').classList.add('hidden');
  }

  // Tap a folder tile to open it
  document.addEventListener('click', function(e) {
    var tile = e.target.closest('.folder-tile');
    if (tile && !e.target.closest('button') && !e.target.closest('input') && !e.target.closest('.note-drag-handle')) {
      openFolderOverlay(parseInt(tile.dataset.folderId));
    }
  });

  // Backdrop: tap closes; dropping an overlay note on it pulls the note
  // out of the folder
  var folderOverlay = document.getElementById('folder-overlay');
  folderOverlay.addEventListener('click', function(e) {
    if (e.target === folderOverlay) closeFolderOverlay();
  });
  folderOverlay.addEventListener('dragover', function(e) {
    if (overlayDraggedNoteId && e.target === folderOverlay) {
      e.preventDefault();
      e.dataTransfer.dropEffect = 'move';
    }
  });
  folderOverlay.addEventListener('drop', function(e) {
    if (overlayDraggedNoteId && e.target === folderOverlay) {
      e.preventDefault();
      moveNoteToFolder(overlayDraggedNoteId, null);
    }
  });

  function moveNoteToFolder(noteId, folderId) {
    fetch('/note/' + noteId + '/move', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ folder_id: folderId })
    }).then(function(r) { return r.json(); })
      .then(function() { window.location.reload(); })
      .catch(function(err) { alert('Failed to move note: ' + err.message); });
  }

  function createFolderFromNotes(targetNoteId, droppedNoteId) {
    fetch('/folders/create-from-notes', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ targetNoteId: targetNoteId, droppedNoteId: droppedNoteId })
    }).then(function(r) { return r.json(); })
      .then(function(result) {
        if (!result.success) throw new Error(result.error || 'Failed');
        window.location.reload();
      })
      .catch(function(err) { alert('Failed to create folder: ' + err.message); });
  }

  function confirmDeleteNote(noteId, noteTitle) {
    noteToDelete = noteId;
    document.getElementById('delete-note-title').textContent = noteTitle;
    document.getElementById('delete-modal').classList.remove('hidden');
  }

  function hideDeleteModal() {
    document.getElementById('delete-modal').classList.add('hidden');
    noteToDelete = null;
  }

  function executeDeleteNote() {
    if (!noteToDelete) return;

    fetch('/note/' + noteToDelete, {
      method: 'DELETE',
      headers: { 'Content-Type': 'application/json' }
    }).then(function(r) { return r.json(); })
      .then(function(result) {
        if (result.success) {
          window.location.reload();
        } else {
          alert('Failed to delete note: ' + (result.error || 'Unknown error'));
        }
      }).catch(function(err) {
        alert('Failed to delete note: ' + err.message);
      }).finally(function() {
        hideDeleteModal();
      });
  }

  function hideImportModal() {
    document.getElementById('import-modal').classList.add('hidden');
    document.getElementById('upload-progress').classList.add('hidden');
  }

  function handlePdfSelect(file) {
    if (!file || file.type !== 'application/pdf') {
      alert('Please select a PDF file');
      return;
    }

    document.getElementById('upload-progress').classList.remove('hidden');

    // Create note with PDF directly
    var formData = new FormData();
    formData.append('pdf', file);
    if (currentFolderId) {
      formData.append('folder_id', currentFolderId);
    }

    fetch('/note/pdf', {
      method: 'POST',
      body: formData
    }).then(function(r) {
        if (!r.ok) {
          return r.json().catch(function() { return {}; }).then(function(body) {
            throw new Error(body.error || ('Server error ' + r.status));
          });
        }
        return r.json();
      })
      .then(function(result) {
        if (result.success && result.noteId) {
          window.location.href = '/note/' + result.noteId;
        } else if (result.success) {
          // Created but no id returned - refresh the list rather than
          // reporting a false failure
          window.location.reload();
        } else {
          throw new Error(result.error || 'Upload failed');
        }
      }).catch(function(err) {
        alert('Upload failed: ' + err.message);
        document.getElementById('upload-progress').classList.add('hidden');
      });
  }

  // Drag and drop support
  var dropzone = document.getElementById('dropzone');
  if (dropzone) {
    dropzone.addEventListener('dragover', function(e) {
      e.preventDefault();
      dropzone.classList.add('border-blue-500', 'bg-blue-50');
    });
    dropzone.addEventListener('dragleave', function() {
      dropzone.classList.remove('border-blue-500', 'bg-blue-50');
    });
    dropzone.addEventListener('drop', function(e) {
      e.preventDefault();
      dropzone.classList.remove('border-blue-500', 'bg-blue-50');
      if (e.dataTransfer.files.length) {
        handlePdfSelect(e.dataTransfer.files[0]);
      }
    });
  }

  // Auto-open import modal if redirected with ?import=1
  if (window.location.search.includes('import=1')) {
    showImportModal();
    history.replaceState({}, '', '/');
  }

  // Drag and drop for note reordering
  var draggedCard = null;
  var dragPlaceholder = null;

  // Dragging starts only from the handle - a long-press elsewhere on the
  // card is inline rename, not reorder
  document.addEventListener('pointerdown', function(e) {
    var handle = e.target.closest('.note-drag-handle');
    if (handle) {
      var card = handle.closest('.note-card');
      if (card) card.draggable = true;
    }
  });
  document.addEventListener('pointerup', function() {
    document.querySelectorAll('.note-card[draggable="true"]').forEach(function(card) {
      card.draggable = false;
    });
  });

  var combineTarget = null;

  function setCombineTarget(card) {
    if (combineTarget === card) return;
    clearCombineTarget();
    combineTarget = card;
    card.classList.add('combine-target');
  }

  function clearCombineTarget() {
    if (combineTarget) {
      combineTarget.classList.remove('combine-target');
      combineTarget = null;
    }
  }

  document.querySelectorAll('.note-card').forEach(function(card) {
    card.addEventListener('dragstart', function(e) {
      draggedCard = card;
      card.style.opacity = '0.5';
      e.dataTransfer.effectAllowed = 'move';

      // Create placeholder
      dragPlaceholder = document.createElement('div');
      dragPlaceholder.className = 'note-placeholder bg-blue-100/50 border-2 border-dashed border-blue-300 rounded-xl';
      dragPlaceholder.style.height = card.offsetHeight + 'px';
    });

    card.addEventListener('dragend', function(e) {
      card.style.opacity = '1';
      if (dragPlaceholder && dragPlaceholder.parentNode) {
        dragPlaceholder.parentNode.removeChild(dragPlaceholder);
      }
      var target = combineTarget;
      clearCombineTarget();
      var dragged = draggedCard;
      draggedCard = null;
      dragPlaceholder = null;

      // Dropped centred on another card: combine (iOS folder behaviour)
      if (target && dragged && dragged.dataset.noteId) {
        if (target.dataset.folderId) {
          moveNoteToFolder(dragged.dataset.noteId, parseInt(target.dataset.folderId));
        } else if (target.dataset.noteId) {
          createFolderFromNotes(parseInt(target.dataset.noteId), parseInt(dragged.dataset.noteId));
        }
        return;
      }

      saveGridOrder();
    });

    card.addEventListener('dragover', function(e) {
      e.preventDefault();
      e.dataTransfer.dropEffect = 'move';

      if (!draggedCard || draggedCard === card) return;

      // Hovering a note over the centre of another note or a folder tile
      // means combine/move-in; edges mean reorder
      var draggedIsNote = !!draggedCard.dataset.noteId;
      var rect = card.getBoundingClientRect();
      var inCentre =
        e.clientX > rect.left + rect.width * 0.2 &&
        e.clientX < rect.right - rect.width * 0.2 &&
        e.clientY > rect.top + rect.height * 0.25 &&
        e.clientY < rect.bottom - rect.height * 0.25;

      if (draggedIsNote && inCentre) {
        setCombineTarget(card);
        return;
      }

      clearCombineTarget();

      var grid = document.getElementById('notes-grid');
      var cards = Array.from(grid.querySelectorAll('.note-card'));
      var draggedIndex = cards.indexOf(draggedCard);
      var targetIndex = cards.indexOf(card);

      if (draggedIndex < targetIndex) {
        card.parentNode.insertBefore(dragPlaceholder, card.nextSibling);
        card.parentNode.insertBefore(draggedCard, card.nextSibling);
      } else {
        card.parentNode.insertBefore(dragPlaceholder, card);
        card.parentNode.insertBefore(draggedCard, card);
      }
    });

    card.addEventListener('dragleave', function() {
      if (combineTarget === card) clearCombineTarget();
    });
  });

  function saveGridOrder() {
    var grid = document.getElementById('notes-grid');
    var cards = Array.from(grid.querySelectorAll('.note-card'));
    var order = cards.map(function(card) {
      return card.dataset.folderId
        ? { type: 'folder', id: parseInt(card.dataset.folderId) }
        : { type: 'note', id: parseInt(card.dataset.noteId) };
    });

    fetch('/notes/reorder', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ order: order })
    }).catch(function(err) {
      console.error('Failed to save order:', err);
    });
  }
