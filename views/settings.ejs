<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Settings - Notes</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    body { font-family: 'Inter', sans-serif; }
  </style>
</head>
<body class="bg-gray-50 min-h-screen">
  <!-- Header -->
  <header class="bg-white border-b border-gray-200">
    <div class="max-w-2xl mx-auto px-4 py-4 flex items-center">
      <a href="/" class="mr-4 text-gray-600 hover:text-gray-800">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
      </a>
      <h1 class="text-xl font-semibold">Settings</h1>
    </div>
  </header>

  <main class="max-w-2xl mx-auto px-4 py-8">
    <!-- Passkeys Section -->
    <section class="bg-white rounded-lg border border-gray-200 p-6 mb-6">
      <h2 class="text-lg font-semibold mb-4">Face ID / Touch ID</h2>
      <p class="text-gray-600 text-sm mb-4">Manage your passkeys for quick, secure login.</p>

      <div id="passkey-list" class="mb-4"></div>

      <button onclick="setupPasskey()" id="setup-btn" class="flex items-center px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
        </svg>
        Add Passkey
      </button>
      <p id="passkey-status" class="mt-2 text-sm text-gray-600"></p>
    </section>

    <!-- Logout Section -->
    <section class="bg-white rounded-lg border border-gray-200 p-6">
      <h2 class="text-lg font-semibold mb-4">Session</h2>
      <button onclick="logout()" class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700">
        Log Out
      </button>
    </section>
  </main>

  <script>
    // Load existing passkeys
    loadPasskeys();

    function loadPasskeys() {
      fetch('/auth/passkey/list')
        .then(function(r) { return r.json(); })
        .then(function(passkeys) {
          var container = document.getElementById('passkey-list');
          if (passkeys.length === 0) {
            container.innerHTML = '<p class="text-gray-500 text-sm mb-4">No passkeys registered.</p>';
            return;
          }
          var html = '<table class="w-full text-sm mb-4"><thead><tr class="text-left text-gray-500"><th class="pb-2">Device</th><th class="pb-2">Added</th><th class="pb-2">Last Used</th><th class="pb-2 w-10"></th></tr></thead><tbody>';
          passkeys.forEach(function(pk) {
            var added = new Date(pk.created_at).toLocaleDateString();
            var lastUsed = pk.last_used_at ? new Date(pk.last_used_at).toLocaleDateString() : 'Never';
            html += '<tr class="border-t border-gray-100"><td class="py-2">' + (pk.device_name || 'Unknown') + '</td><td class="py-2">' + added + '</td><td class="py-2">' + lastUsed + '</td>';
            html += '<td class="py-2"><button onclick="deletePasskey(' + pk.id + ')" class="text-red-600 hover:text-red-800">&times;</button></td></tr>';
          });
          html += '</tbody></table>';
          container.innerHTML = html;
        });
    }

    function deletePasskey(id) {
      if (confirm('Remove this passkey?')) {
        fetch('/auth/passkey/' + id + '/delete', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' }
        }).then(function() {
          loadPasskeys();
        });
      }
    }

    // Base64url conversion
    function base64urlToBuffer(base64url) {
      var base64 = base64url.replace(/-/g, '+').replace(/_/g, '/');
      var padding = '='.repeat((4 - base64.length % 4) % 4);
      var binary = atob(base64 + padding);
      var bytes = new Uint8Array(binary.length);
      for (var i = 0; i < binary.length; i++) {
        bytes[i] = binary.charCodeAt(i);
      }
      return bytes.buffer;
    }

    function bufferToBase64url(buffer) {
      var bytes = new Uint8Array(buffer);
      var binary = '';
      for (var i = 0; i < bytes.length; i++) {
        binary += String.fromCharCode(bytes[i]);
      }
      return btoa(binary).replace(/\+/g, '-').replace(/\//g, '_').replace(/=+$/, '');
    }

    function getDeviceName() {
      var ua = navigator.userAgent;
      if (/iPhone/.test(ua)) return 'iPhone';
      if (/iPad/.test(ua)) return 'iPad';
      if (/Macintosh/.test(ua) && navigator.maxTouchPoints > 0) return 'iPad';
      if (/Macintosh/.test(ua)) return 'Mac';
      if (/Android/.test(ua)) return 'Android';
      if (/Windows/.test(ua)) return 'Windows';
      return 'Unknown Device';
    }

    async function setupPasskey() {
      var statusEl = document.getElementById('passkey-status');
      var btn = document.getElementById('setup-btn');
      statusEl.textContent = 'Setting up...';
      btn.disabled = true;

      try {
        var optionsRes = await fetch('/auth/passkey/register-options');
        var options = await optionsRes.json();

        if (options.error) throw new Error(options.error);

        options.challenge = base64urlToBuffer(options.challenge);
        options.user.id = base64urlToBuffer(options.user.id);
        if (options.excludeCredentials) {
          options.excludeCredentials = options.excludeCredentials.map(function(c) {
            return { ...c, id: base64urlToBuffer(c.id) };
          });
        }

        var credential = await navigator.credentials.create({ publicKey: options });

        var response = {
          id: credential.id,
          rawId: bufferToBase64url(credential.rawId),
          type: credential.type,
          response: {
            clientDataJSON: bufferToBase64url(credential.response.clientDataJSON),
            attestationObject: bufferToBase64url(credential.response.attestationObject),
          },
        };
        if (credential.response.getTransports) {
          response.response.transports = credential.response.getTransports();
        }

        var verifyRes = await fetch('/auth/passkey/register', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ response: response, deviceName: getDeviceName() })
        });
        var result = await verifyRes.json();

        if (result.success) {
          statusEl.textContent = 'Passkey added successfully!';
          statusEl.style.color = '#059669';
          loadPasskeys();
        } else {
          throw new Error(result.error || 'Setup failed');
        }
      } catch (err) {
        console.error('Setup error:', err);
        statusEl.textContent = 'Setup failed: ' + err.message;
        statusEl.style.color = '#dc2626';
      }

      btn.disabled = false;
    }

    function logout() {
      fetch('/auth/logout', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' }
      }).then(function() {
        window.location.href = '/login';
      });
    }
  </script>
</body>
</html>
